{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build C++ File",
      "type": "shell",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "windows": {
        "command": "g++",
        "args": [
          "-fdiagnostics-color=always",
          "-g",
          "${file}",
          "-o",
          "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe"
        ]
      },
      "osx": {
        "command": "clang++",
        "args": [
          "-fcolor-diagnostics",
          "-g",
          "-std=c++17",
          "${file}",
          "-o",
          "${workspaceFolder}/build/${fileBasenameNoExtension}.out"
        ]
      }
    }
  ]
}
