{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "g++.exe - 编译并调试当前文件",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}\\${fileBasenameNoExtension}.exe", // 动态识别：当前目录下的 同名.exe
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}", // 动态识别：工作目录设置为当前文件所在目录
      "environment": [],
      "externalConsole": true, // true 表示弹出黑窗口运行；改 false 会在底部的终端运行
      "MIMode": "gdb",
      "miDebuggerPath": "gdb.exe", // 默认系统环境变量中的 gdb
      "setupCommands": [
        {
          "description": "为 gdb 启用整齐打印",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "C/C++: g++.exe build active file" // 调试前，先呼叫 tasks.json 进行编译
    }
  ]
}
